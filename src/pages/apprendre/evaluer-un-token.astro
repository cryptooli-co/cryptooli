    }
    .retour { font-size: 0.9rem; margin-bottom: 3rem; }
    .retour a { color: var(--muted); text-decoration: none; }
    .retour a:hover { color: var(--accent); }
    h1 {
      font-size: clamp(1.9rem, 5vw, 2.6rem);
      line-height: 1.2;
      letter-spacing: -0.02em;
      margin: 0 0 1rem;
    }
    .chapeau {
      color: var(--muted);
      font-size: 1.05rem;
      margin-bottom: 2.5rem;
    }
    .note {
      background: #0c1526;
      border-left: 3px solid var(--accent);
      border-radius: 6px;
      padding: 1.2rem 1.4rem;
      margin-bottom: 3rem;
    }
    .note p { margin: 0; font-size: 0.95rem; color: var(--muted); }
    h2 {
      font-size: 1.4rem;
      margin-top: 3.5rem;
      margin-bottom: 1rem;
      letter-spacing: -0.01em;
    }
    p { margin: 0 0 1.2rem; }
    figure {
      margin: 2.5rem 0;
      padding: 1.5rem;
      background: #0c1526;
      border: 1px solid #17223a;
      border-radius: 12px;
    }
    figure img { width: 100%; height: auto; display: block; }
    figcaption {
      color: var(--muted);
      font-size: 0.85rem;
      text-align: center;
      margin-top: 1rem;
    }
    ul { padding-left: 1.2rem; }
    li { margin-bottom: 0.7rem; }
