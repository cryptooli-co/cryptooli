      margin-top: 3.5rem;
      margin-bottom: 1rem;
      letter-spacing: -0.01em;
    }
    p { margin: 0 0 1.2rem; }
    figure {
      margin: 2.5rem 0;
      padding: 1.5rem;
      background: #0c1526;
      border: 1px solid #17223a;
      border-radius: 12px;
    }
    figure img { width: 100%; height: auto; display: block; }
    figcaption {
      color: var(--muted);
      font-size: 0.85rem;
      text-align: center;
      margin-top: 1rem;
    }
    ul { padding-left: 1.2rem; }
    li { margin-bottom: 0.7rem; }
    ul.check li { color: var(--text); }
    .fin { margin-top: 2rem; }
    footer {
